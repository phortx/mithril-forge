{
  "$schema": "https://schema.railpack.com",
  "steps": {
    "build": {
      "commands": [
        "curl -fsSL https://bun.sh/install | bash",
        "export PATH=\"$HOME/.bun/bin:$PATH\" && ./gradlew :backend:bootJar"
      ]
    }
  },
  "deploy": {
    "startCommand": "java -jar backend/build/libs/backend-0.0.1-SNAPSHOT.jar"
  }
}
