{
  "name": "mithril-forge",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "bun --bun vite",
    "build": "bun --bun tsc -b && bun --bun vite build",
    "lint": "bun --bun eslint .",
    "typecheck": "bun --bun tsc -b --noEmit",
    "preview": "bun --bun vite preview",
    "test": "bun test src/",
    "test:watch": "bun test --watch src/",
    "test:e2e": "bun --bun playwright test",
    "test:e2e:ui": "bun --bun playwright test --ui",
    "test:e2e:install": "bun --bun playwright install chromium --with-deps"
  },
  "dependencies": {
    "lucide-react": "^1.17.0",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "react-hot-toast": "^2.6.0",
    "react-router-dom": "^7.16.0",
    "usehooks-ts": "^3.1.1",
    "vanilla-cookieconsent": "^3.1.0"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.4",
    "@happy-dom/global-registrator": "^20.10.1",
    "@tailwindcss/vite": "^4.3.0",
    "@testing-library/dom": "^10.4.1",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@playwright/test": "^1.49.1",
    "@types/bun": "^1.3.14",
    "@types/node": "^22.0.0",
    "@types/react": "^19.2.16",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.2",
    "eslint": "^9.39.4",
    "eslint-plugin-react-hooks": "^7.1.1",
    "eslint-plugin-react-refresh": "^0.5.2",
    "globals": "^17.6.0",
    "tailwindcss": "^4.3.0",
    "typescript": "~5.9.3",
    "typescript-eslint": "^8.60.1",
    "vite": "^8.0.16"
  }
}
